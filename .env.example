# Copy this file to .env and fill in your own values (never commit .env).
# Get these from https://developer.spotify.com/dashboard after creating an app.

SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Must exactly match a Redirect URI registered on the Spotify app.
# Local dev default (matches `streamlit run app.py` on its default port):
SPOTIFY_REDIRECT_URI=http://localhost:8501

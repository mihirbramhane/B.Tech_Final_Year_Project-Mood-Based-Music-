# Copy to .streamlit/secrets.toml for local use, or paste into your
# Streamlit Community Cloud app's "Secrets" settings when deploying.
# Never commit the real secrets.toml file.

SPOTIFY_CLIENT_ID = "your_client_id_here"
SPOTIFY_CLIENT_SECRET = "your_client_secret_here"

# Must exactly match a Redirect URI registered on the Spotify app, e.g.
# your deployed app's HTTPS URL: https://your-app.streamlit.app
SPOTIFY_REDIRECT_URI = "https://your-app.streamlit.app"
